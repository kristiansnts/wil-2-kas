generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model KasUmum {
  id        String   @id @default("singleton")
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
}

model Division {
  id           String        @id @default(cuid())
  name         String
  balance      Float         @default(0)
  transactions Transaction[]
  events       Event[]
  createdAt    DateTime      @default(now())
}

model Event {
  id           String        @id @default(cuid())
  name         String
  date         DateTime
  divisionId   String
  division     Division      @relation(fields: [divisionId], references: [id])
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id            String    @id @default(cuid())
  date          DateTime
  desc          String
  amount        Float
  type          String
  scope         String
  kategori      String?
  divisionId    String?
  division      Division? @relation(fields: [divisionId], references: [id])
  eventId       String?
  event         Event?    @relation(fields: [eventId], references: [id])
  refDivId      String?
  attachmentUrl String?
  attachmentKey String?
  createdAt     DateTime  @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  desc       String
  actorRole  String
  divisionId String?
  createdAt  DateTime @default(now())
}

model Pastor {
  id          String             @id @default(cuid())
  name        String
  title       String
  status      String
  pelayanan   String?
  createdAt   DateTime           @default(now())
  submissions PastorSubmission[]
}

model Meeting {
  id             String             @id @default(cuid())
  token          String             @unique @default(cuid())
  month          String
  deadline       DateTime
  status         String             @default("open")
  createdAt      DateTime           @default(now())
  submissions    PastorSubmission[]
  setorDate      DateTime?
  setorNetAmount Int?
  setorItems     SetorBantuan[]
}

model SetorBantuan {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  desc      String
  amount    Int
}

model PastorSubmission {
  id           String       @id @default(cuid())
  meetingId    String
  meeting      Meeting      @relation(fields: [meetingId], references: [id])
  pastorId     String
  pastor       Pastor       @relation(fields: [pastorId], references: [id])
  persepuluhan Int          @default(0)
  bulan        Int          @default(1)
  status       String       @default("pending")
  ipAddress    String?
  submittedAt  DateTime     @default(now())
  wadahEntries WadahEntry[]
}

model WadahEntry {
  id           String           @id @default(cuid())
  submissionId String
  submission   PastorSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  divisionId   String
  amount       Int
}
